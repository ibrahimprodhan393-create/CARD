SECRET_KEY=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# For Neon Postgres, paste the pooled connection string from Neon.
# Keep sslmode=require in the URL when Neon provides it.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require

# Leave DATABASE_URL empty for local SQLite fallback.
# SQLITE_PATH=russian_market.db
